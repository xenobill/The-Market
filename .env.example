# Copy this file to `.env` and fill in the real credentials for local development
# Cloudinary (get from https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email (Gmail app password recommended, or other SMTP service)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_password

# Session security: REQUIRED. Generate a random string (at least 32 characters).
# Example on Linux/Mac: SESSION_SECRET=$(openssl rand -hex 16)
# Or use an online random generator. This MUST be set in production.
SESSION_SECRET=your_random_session_secret_at_least_32_characters

# Migration secret for bulk user imports (optional; leave empty to use admin session only)
MIGRATION_SECRET=your_migration_secret
